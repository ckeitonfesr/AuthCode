{
  "version": 2,
  "buildCommand": null,
  "functions": {
    "api/svc/[...path].js": { "maxDuration": 15 }
  },
  "rewrites": [
    { "source": "/api/svc/:path*", "destination": "/api/svc/[...path]" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security",  "value": "max-age=31536000; includeSubDomains; preload" },
        { "key": "X-Content-Type-Options",     "value": "nosniff" },
        { "key": "X-Frame-Options",            "value": "DENY" },
        { "key": "Referrer-Policy",            "value": "no-referrer" },
        { "key": "Permissions-Policy",         "value": "geolocation=(), camera=(), microphone=()" },
        { "key": "Content-Security-Policy",    "value": "default-src 'none'; frame-ancestors 'none';" },
        { "key": "Access-Control-Allow-Methods","value": "POST, OPTIONS, GET, PATCH, DELETE" },
        { "key": "Access-Control-Allow-Headers","value": "Content-Type, x-request-token, x-device-id, x-app-key, x-timestamp, x-signature, x-user-token, x-webhook-secret, authorization, apikey, accept-profile, prefer" }
      ]
    }
  ]
}
